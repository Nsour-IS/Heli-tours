# Supabase Configuration
# Get these values from: Supabase Dashboard → Settings → API

# Project URL (found in Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public Key (found in Supabase Dashboard → Settings → API)
# This key is safe to use in client-side code
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (found in Supabase Dashboard → Settings → API)
# ⚠️ KEEP THIS SECRET! Never expose in client-side code
# Only use server-side (API routes, coordinator dashboard)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =====================================================
# SETUP INSTRUCTIONS
# =====================================================
#
# 1. Copy this file to .env.local:
#    cp .env.example .env.local
#
# 2. Get your Supabase credentials:
#    - Go to https://supabase.com
#    - Open your project dashboard
#    - Navigate to Settings → API
#    - Copy the values
#
# 3. Replace the placeholder values above with your actual credentials
#
# 4. Never commit .env.local to git (already in .gitignore)
#
# =====================================================
# NOTES
# =====================================================
#
# - NEXT_PUBLIC_* variables are exposed to the browser
# - Variables without NEXT_PUBLIC_ prefix are server-only
# - Service role key bypasses Row Level Security - use carefully
# - All environment variables are required for the app to work
#
